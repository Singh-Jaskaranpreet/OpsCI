# Copy this file to `.env` and fill in the values before running `docker compose up`

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=movies_db

# --- TMDB API ---
# Get one at https://www.themoviedb.org/settings/api  (v4 Read Access Token)
TMDB_TOKEN=your_tmdb_v4_read_access_token_here

# --- Host-side port (the only port exposed to your PC) ---
FRONTEND_PORT=8080

